# LocaMaster Pro V2 - Environment Variables for Production

# === REQUIRED FOR PRODUCTION ===
NODE_ENV=production
NEXTAUTH_SECRET=your-super-secret-key-here-min-32-characters-long
NEXTAUTH_URL=https://your-domain.vercel.app

# === APPLICATION SETTINGS ===
NEXT_PUBLIC_APP_NAME="LocaMaster Pro V2"
NEXT_PUBLIC_APP_VERSION="2.0.0"
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# === OPTIONAL FEATURES ===
NEXT_PUBLIC_ENABLE_CUSTOMER_PORTAL=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# === FOR FUTURE DATABASE INTEGRATION ===
# DATABASE_URL="postgresql://username:password@host:5432/database"

# === FOR FUTURE EMAIL INTEGRATION ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL="noreply@locamaster.com"

# === FOR FUTURE PAYMENT INTEGRATION ===
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# === FOR FUTURE STORAGE INTEGRATION ===
# S3_BUCKET_NAME=locamaster-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...

# === FOR MONITORING (OPTIONAL) ===
# SENTRY_DSN=https://...
# ANALYTICS_ID=GA-...
